---
import Layout from '../layouts/Layout.astro';
import Columnaizq from '../components/Columnaizq.astro';
import Titulo from '../components/Titulo.astro';
import Educacion from '../components/Educacion.astro';
import Experiencia from '../components/Experiencia.astro';
import Habilidades from '../components/Habilidades.astro';
---

<Layout>
  <div class="max-w-5xl mx-auto bg-gray-200 grid grid-cols-1 md:grid-cols-[1fr_3fr] mt-10 mb-10 p-6 gap-6">
    
    <aside class="bg-gray-200 p-6 rounded-2xl">
      <Columnaizq />
    </aside>

    <div class="flex flex-col gap-6 p-6 bg-white rounded-3xl">
      <main class="flex flex-col gap-6">
        <Titulo />
        <Educacion />
        <Experiencia />
        <Habilidades />
      </main>
    </div>

  </div>
</Layout>
